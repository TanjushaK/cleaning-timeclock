	<array>
		<string>UIInterfaceOrientationPortrait</string>
		<string>UIInterfaceOrientationPortraitUpsideDown</string>
		<string>UIInterfaceOrientationLandscapeLeft</string>
		<string>UIInterfaceOrientationLandscapeRight</string>
	</array>
	<key>UIViewControllerBasedStatusBarAppearance</key>
	<true/>
	<key>NSLocationWhenInUseUsageDescription</key>
	<string>Location is used to verify you are at the job site when starting or ending a shift.</string>
	<key>NSFaceIDUsageDescription</key>
	<string>Use Face ID to unlock your saved sign-in on this device. Your account password is not stored.</string>
	<key>NSCameraUsageDescription</key>
	<string>Camera access is used to capture profile or job-site photos when requested by the user.</string>
	<key>NSPhotoLibraryUsageDescription</key>
	<string>Photo library access is used to upload profile or job-site photos when selected by the user.</string>
