NEXT_PUBLIC_SUPABASE_URL=
NEXT_PUBLIC_SUPABASE_ANON_KEY=
SUPABASE_SERVICE_ROLE_KEY=
ME_USE_RLS=0

# Переключатель языка (RU/UK/EN/NL) и статические фразы — в коде (I18nProvider, AutoTranslate).
# Локаль: cookie ct_lang (и localStorage).
#
# Опционально: DeepL для строк без словаря (динамический текст). Только на сервере — не NEXT_PUBLIC_.
# Ключ: https://www.deepl.com/pro-api — бесплатный заканчивается на :fx (тогда api-free.deepl.com).
DEEPL_AUTH_KEY=

# Опционально на проде (VPS): короткая метка сборки для /api/pwa/sw-kill (иначе берётся из .next/BUILD_ID)
# GIT_COMMIT_SHA=
# DEPLOY_SHA=

# Локальна збірка Capacitor (опціонально): URL WebView, інакше з capacitor.config.ts
# CAP_SERVER_URL=https://timeclock.tanjusha.nl
