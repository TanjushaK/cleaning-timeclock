# Public (client-side)
NEXT_PUBLIC_SUPABASE_URL=
NEXT_PUBLIC_SUPABASE_ANON_KEY=

# Server-only (do NOT expose)
SUPABASE_SERVICE_ROLE_KEY=

# PWA / Service Worker
# SAFE DEFAULT: disabled. Enable only on Preview first.
PWA_SW_ENABLED=0
# Temporary kill switch (clears ct-* caches + unregister SW). Set to 1, open the app once, then set back to 0.
PWA_SW_KILL=0
