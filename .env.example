DATABASE_URL=postgres://timeclock:change-me@127.0.0.1:5432/timeclock
JWT_SECRET=change-me-long-random-string
STORAGE_SIGNING_SECRET=change-me-another-long-random-string
# Локальный self-host: совпадает с URL приложения (cookies / redirects)
APP_PUBLIC_ORIGIN=http://localhost:3001
UPLOAD_ROOT=./var/uploads

# Локально: GET /api/geocode без Bearer (лимит запросов). На проде держите 0 и используйте admin token.
GEOCODE_PUBLIC=1

# Один раз для scripts/setup-local-db.mjs и неинтерактивного fix-local-postgres.ps1 (пароль суперпользователя postgres)
# POSTGRES_ADMIN_PASSWORD=
# POSTGRES_ADMIN_USER=postgres
# Альтернатива: один секрет в файле (первая строка), путь можно задать и через POSTGRES_ADMIN_PASSWORD_FILE
# POSTGRES_ADMIN_PASSWORD_FILE=
# Доверять паролю из текущего shell (только если вы сами выставили POSTGRES_ADMIN_PASSWORD): POSTGRES_INHERIT_ADMIN_PASSWORD=1
# Неинтерактивный запуск: .\fix-local-postgres.ps1 -NonInteractive (нужен пароль в .env.local или в файле выше)

# После успешной миграции: npm run bootstrap:admin (или задать здесь и дернуть скрипт)
# BOOTSTRAP_ADMIN_EMAIL=
# BOOTSTRAP_ADMIN_PASSWORD=

JWT_ACCESS_TTL_SECONDS=900
REFRESH_TOKEN_TTL_SECONDS=2592000
PASSWORD_RECOVERY_TTL_SECONDS=3600
# Optional alias (minutes); if set (>0), overrides PASSWORD_RECOVERY_TTL_SECONDS
# PASSWORD_RESET_TTL_MINUTES=60
SMS_OTP_TTL_SECONDS=600

SITE_PHOTOS_BUCKET=site-photos
WORKER_PHOTOS_BUCKET=site-photos/workers
SITE_PHOTOS_SIGNED_URL_TTL=86400
WORKER_PHOTOS_SIGNED_URL_TTL=3600

# Исходящая почта: 1 + RESEND_API_KEY + MAIL_FROM → письма через Resend. При 0 или без ключей — только var/logs/auth-delivery.log (без дубля в консоль).
EMAIL_SEND_ENABLED=0
RESEND_API_KEY=
MAIL_FROM=
# Устар.: SMTP пока не реализован; для совместимости ключей см. lib/email/smtp.ts
# SMTP_HOST=
# SMTP_PORT=587
# SMTP_USER=
# SMTP_PASS=

# SMS (Twilio): 1 + TWILIO_* (или устар. SMS_TWILIO_*) — иначе OTP пишется в var/logs/auth-delivery.log
SMS_SEND_ENABLED=0
# TWILIO_ACCOUNT_SID=
# TWILIO_AUTH_TOKEN=
# TWILIO_FROM_NUMBER=
# Алиасы: SMS_TWILIO_ACCOUNT_SID, SMS_TWILIO_AUTH_TOKEN, SMS_TWILIO_FROM

# Опционально: короткая метка сборки для /api/pwa/sw-kill
# GIT_COMMIT_SHA=
# DEPLOY_SHA=

# Локальна збірка Capacitor (опціонально): URL WebView, інакше з capacitor.config.ts
# CAP_SERVER_URL=https://timeclock.tanjusha.nl
